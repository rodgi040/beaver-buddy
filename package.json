{
  "name": "beaver-buddy",
  "version": "0.1.0",
  "private": true,
  "description": "Pixel-art desktop beaver overlay for macOS",
  "main": "dist/main/main.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc && cp src/renderer/index.html dist/renderer/index.html",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
