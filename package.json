{
  "name": "beaver-buddy",
  "version": "0.1.0",
  "private": true,
  "description": "Pixel-art desktop beaver overlay for macOS and Windows",
  "author": "AI Beavers",
  "main": "dist/main/main.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc && tsc -p src/renderer/tsconfig.json && node scripts/build-assets.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/renderer/tsconfig.json && tsc --noEmit -p scripts/gen-sprites/tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "assets:build": "node scripts/gen-sprites/build.ts",
    "assets:ingest": "node scripts/gen-sprites/ingest-images.mjs",
    "usage:cli": "npm run build && node scripts/usage-cli.js"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
