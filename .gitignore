node_modules/
dist/
release/
*.log
.DS_Store

# Local build-loop artifacts: git worktrees and scratch context. Never committed.
.worktrees/
.context/

# Asset sources & intermediates. Committed as source assets: rig-ready
# character parts (assets-src/parts/) and curated reference images
# (assets-src/reference/) — the material new figures are built from.
# Local-only: raw ComfyUI dumps (comfyui/), pre-review bakes (baked/),
# user-supplied originals (e.g. beaver/) — see CLAUDE.md "Assets".
assets-src/*
!assets-src/parts/
!assets-src/reference/

# Local agent-skill install location. The committed source of truth lives in
# skills/ and is installed via `npm run skills:install` (see CONTRIBUTING.md).
# Local skill iterations (Flightplan, ComfyUI, ...) stay untracked here.
.agents/skills/

# Code-signing certificates never enter the repo; dev PFX files stay local,
# CI certs live in GitHub Actions secrets (docs/code-signing.md).
*.pfx
*.p12

# Flightplan planning state — local-only, never committed (linked from
# CLAUDE.md/AGENTS.md). Anchored to the repo root so the pattern can never
# swallow repo files of the same name at deeper paths.
/.flightplan/

# Agent tooling stays maintainer-local: Flightplan fp-* skills/commands/agents
# are workflow scaffolding, not project content. The vendored PixiJS skills
# under .agents/skills/pixijs* ARE committed (pinned by skills-lock.json).
/.claude/
/.agents/skills/*
!/.agents/skills/pixijs*/
