node_modules/
dist/
release/
*.log
.DS_Store

# Local build-loop artifacts: git worktrees and scratch context. Never committed.
.worktrees/
.context/

# User-supplied source images for scripts/gen-sprites/ingest-images.mjs.
# Originals live outside the repo; only the ingested sheets under
# assets/sprites/ are committed (CLAUDE.md: no raw image-gen intermediates).
assets-src/

# Local /fp-new-projekt slash-command template files. Imported for local
# scaffolding only; never committed.
.fp-new-projekt/

# Code-signing certificates never enter the repo; dev PFX files stay local,
# CI certs live in GitHub Actions secrets (docs/code-signing.md).
*.pfx
*.p12
